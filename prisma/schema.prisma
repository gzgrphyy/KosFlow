generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum TenancyStatus {
  ACTIVE
  ENDED
}

enum InvoiceStatus {
  BELUM_LUNAS
  SEBAGIAN
  LUNAS
  TELAT
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentMethod {
  CASH
  TRANSFER
  QRIS
  E_WALLET
  LAINNYA
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  verifiedPayments Payment[]
  auditLogs        AuditLog[]

  @@map("users")
}

model Room {
  id          String     @id @default(uuid())
  roomNumber  String     @unique
  monthlyRate Decimal    @db.Decimal(12, 2)
  status      RoomStatus @default(AVAILABLE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenancies Tenancy[]

  @@map("rooms")
}

model Tenant {
  id            String   @id @default(uuid())
  fullName      String
  phone         String
  email         String?
  ktpEncrypted  Bytes
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenancies Tenancy[]

  @@map("tenants")
}

model Tenancy {
  id        String        @id @default(uuid())
  roomId    String
  tenantId  String
  startDate DateTime
  endDate   DateTime?
  status    TenancyStatus @default(ACTIVE)
  createdAt DateTime      @default(now())

  room     Room      @relation(fields: [roomId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  invoices Invoice[]

  // Mencegah 1 kamar punya lebih dari 1 tenancy aktif dalam satu waktu
  @@index([roomId, status])
  @@map("tenancies")
}

model Invoice {
  id        String        @id @default(uuid())
  tenancyId String
  period    String        // format "2026-07"
  dueDate   DateTime
  status    InvoiceStatus @default(BELUM_LUNAS)
  createdAt DateTime      @default(now())

  tenancy Tenancy       @relation(fields: [tenancyId], references: [id])
  items   InvoiceItem[]
  payments Payment[]

  @@unique([tenancyId, period])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  amount      Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id             String        @id @default(uuid())
  invoiceId      String
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod?
  referenceNo    String?
  proofUrl       String
  paymentDate    DateTime
  status         PaymentStatus @default(PENDING)
  verifiedById   String?
  verifiedAt     DateTime?
  notes          String?
  createdAt      DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  verifiedBy User?   @relation(fields: [verifiedById], references: [id])

  @@map("payments")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}